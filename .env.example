# ============================================================
#  Showstopper — AI News Analyst  |  Environment Variables
# ============================================================
# Copy this file to .env and fill in your keys.
# NEVER commit your real .env to version control.

# ── News Sources ─────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_org_key_here

# ── LLM Provider (choose one or both) ───────────────────────
# Option 1: OpenAI  (https://platform.openai.com)
OPENAI_API_KEY=your_openai_key_here

# Option 2: Groq  — FREE  (https://console.groq.com)
GROQ_API_KEY=your_groq_key_here

# ── Active provider: "openai" | "groq" | "demo" ─────────────
# "demo" mode skips LLM and returns retrieved chunks only
LLM_PROVIDER=demo
