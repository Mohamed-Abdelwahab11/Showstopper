# ============================================================
#  Showstopper — .gitignore
# ============================================================

# ── Secrets (NEVER commit!) ──────────────────────────────────
.env
*.env
secrets.yaml

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# ── Virtual Environments ─────────────────────────────────────
venv/
env/
.venv/
.env/

# ── FAISS Index (large binary files) ─────────────────────────
data/faiss_index/
data/*.pkl
data/faiss_metadata.pkl

# ── Jupyter / IPython ────────────────────────────────────────
.ipynb_checkpoints
*.ipynb

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.iml

# ── Logs & Cache ─────────────────────────────────────────────
*.log
logs/
.cache/
joblib_cache/

# ── Sentence Transformers Cache ──────────────────────────────
~/.cache/huggingface/

# ── pytest ───────────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
